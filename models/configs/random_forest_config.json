{
  "training_data": "../data/nba_model_training_data.csv",
  "predict_season": "2025-26",
  "tune_season": "2024-25",

  "use_per_100": true,
  "test": false,
  "tune": false,

  "max_depth": 7,
  "max_features": 6,
  "playoff_trees": 50,
  "conference_trees": 200,

  "raw_features": [
    "PLUS_MINUS",
    "OFF_RATING_CUSTOM",
    "FG_PCT",
    "FG3_PCT",
    "FT_PCT",
    "AST",
    "REB",
    "TOV",
    "BLK"
  ],

  "per_100_features": [
    "PLUS_MINUS",
    "OFF_RATING_CUSTOM",
    "FG_PCT",
    "FG3_PCT",
    "FT_PCT",
    "AST_PER_100",
    "REB_PER_100",
    "TOV_PER_100",
    "BLK_PER_100"
  ],

  "output_pred_dest": "../eval/forest_output_predictions/forest_2025_26_predictions.csv",
  "output_stats_dest": "../eval/forest_output_predictions/forest_2025_26_pred_stats.csv",
  "output_tune_dest": "../eval/forest_output_tuning/graphs",
  "output_tune_stats_dest": "../eval/forest_output_tuning/stats",

  "output_cols": [
    "TEAM_NAME",
    "SEASON_ID",
    "PRED_MADE_PLAYOFFS",
    "PRED_MADE_CONF_FINALS",
    "PRED_PLAYOFF_PROB",
    "PRED_CONF_FINALS_PROB"
  ]
}